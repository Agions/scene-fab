/* ============================================================
   Scene-Fab - Dark Theme
   Unified color palette:
     Primary: #06b6d4  |  Accent: #8b5cf6
     Background: #0a0a0a  |  Surface: #111111
     Border: #222222  |  Text: #e5e5e5
   ============================================================ */

QWidget {
    background-color: #0a0a0a;
    color: #e5e5e5;
    font-family: system-ui, -apple-system, "Segoe UI", "Microsoft YaHei", "PingFang SC", "Hiragino Sans GB", Arial, sans-serif;
    font-size: 14px;
    selection-background-color: #06b6d4;
    selection-color: #ffffff;
}

QMainWindow,
QDialog {
    background-color: #0a0a0a;
}

QWidget[objectName="left_panel"] {
    background-color: #111111;
    border-right: 1px solid #222222;
    min-width: 220px;
    max-width: 280px;
}

QLabel {
    background-color: transparent;
    color: #e5e5e5;
}

QLabel[objectName="app_title"] {
    color: #06b6d4;
    font-size: 20px;
    font-weight: 700;
    padding: 20px 20px 16px;
    letter-spacing: 0px;
}

QLabel[objectName="page_title"],
QLabel[objectName="section_title"] {
    color: #ffffff;
    font-size: 18px;
    font-weight: 700;
}

QLabel[objectName="muted_label"],
QLabel[objectName="hint_label"] {
    color: #a3a3a3;
}

QPushButton {
    background-color: #111111;
    border: 1px solid #222222;
    border-radius: 7px;
    color: #e5e5e5;
    padding: 9px 16px;
    min-height: 34px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #1a1a1a;
    border-color: #06b6d4;
    color: #ffffff;
}

QPushButton:pressed {
    background-color: #0a0a0a;
    border-color: #0891b2;
}

QPushButton:disabled {
    background-color: #111111;
    border-color: #222222;
    color: #525252;
}

QPushButton[objectName="primary_button"] {
    background-color: #06b6d4;
    border-color: #06b6d4;
    color: #ffffff;
}

QPushButton[objectName="primary_button"]:hover {
    background-color: #22d3ee;
    border-color: #22d3ee;
}

QPushButton[objectName="primary_button"]:pressed {
    background-color: #0891b2;
    border-color: #0891b2;
}

QPushButton[objectName="secondary_button"] {
    background-color: #111111;
    border-color: #222222;
    color: #d4d4d4;
}

QPushButton[objectName="ghost_button"] {
    background-color: transparent;
    border-color: transparent;
    color: #a3a3a3;
}

QPushButton[objectName="ghost_button"]:hover {
    background-color: #111111;
    color: #e5e5e5;
}

QPushButton[objectName="danger_button"] {
    background-color: #e11d48;
    border-color: #e11d48;
    color: #ffffff;
}

QPushButton[objectName="danger_button"]:hover {
    background-color: #fb7185;
    border-color: #fb7185;
}

QPushButton[objectName="nav_button"] {
    background-color: transparent;
    border: none;
    border-radius: 7px;
    color: #a3a3a3;
    padding: 13px 18px;
    text-align: left;
    min-height: 42px;
    margin: 3px 10px;
}

QPushButton[objectName="nav_button"]:hover {
    background-color: #111111;
    color: #06b6d4;
}

QPushButton[objectName="nav_button"]:checked {
    background-color: #0a0a0a;
    border-left: 4px solid #06b6d4;
    color: #ffffff;
    font-weight: 700;
}

QPushButton[objectName="nav_icon_btn"] {
    background-color: transparent;
    border: none;
    border-radius: 8px;
    min-width: 36px;
    min-height: 36px;
    padding: 4px;
}

QPushButton[objectName="nav_icon_btn"]:hover,
QPushButton[objectName="nav_icon_btn"]:checked {
    background-color: #111111;
}

QLineEdit,
QTextEdit,
QPlainTextEdit,
QSpinBox,
QDoubleSpinBox {
    background-color: #0a0a0a;
    border: 1px solid #222222;
    border-radius: 7px;
    color: #e5e5e5;
    padding: 9px 12px;
    min-height: 34px;
}

QLineEdit:hover,
QTextEdit:hover,
QPlainTextEdit:hover,
QSpinBox:hover,
QDoubleSpinBox:hover {
    border-color: #404040;
}

QLineEdit:focus,
QTextEdit:focus,
QPlainTextEdit:focus,
QSpinBox:focus,
QDoubleSpinBox:focus {
    border-color: #06b6d4;
}

QLineEdit:disabled,
QTextEdit:disabled,
QPlainTextEdit:disabled {
    background-color: #111111;
    color: #525252;
}

QComboBox {
    background-color: #0a0a0a;
    border: 1px solid #222222;
    border-radius: 7px;
    color: #e5e5e5;
    padding: 8px 12px;
    min-height: 34px;
}

QComboBox:hover,
QComboBox:focus {
    border-color: #06b6d4;
}

QComboBox::drop-down {
    border: none;
    width: 26px;
}

QComboBox QAbstractItemView {
    background-color: #111111;
    border: 1px solid #222222;
    border-radius: 7px;
    color: #e5e5e5;
    selection-background-color: #06b6d4;
    selection-color: #ffffff;
    padding: 4px;
}

QCheckBox,
QRadioButton {
    color: #e5e5e5;
    spacing: 8px;
    background-color: transparent;
}

QCheckBox::indicator,
QRadioButton::indicator {
    width: 16px;
    height: 16px;
}

QCheckBox::indicator:unchecked,
QRadioButton::indicator:unchecked {
    background-color: #0a0a0a;
    border: 1px solid #404040;
}

QCheckBox::indicator:checked,
QRadioButton::indicator:checked {
    background-color: #06b6d4;
    border: 1px solid #06b6d4;
}

QFrame,
QGroupBox {
    background-color: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
}

QGroupBox {
    margin-top: 12px;
    padding: 14px 12px 12px 12px;
    font-weight: 700;
    color: #ffffff;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px;
    color: #06b6d4;
}

QTabWidget::pane {
    background-color: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
}

QTabBar::tab {
    background-color: #0a0a0a;
    border: 1px solid #222222;
    border-bottom: none;
    border-top-left-radius: 7px;
    border-top-right-radius: 7px;
    color: #a3a3a3;
    padding: 9px 16px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background-color: #111111;
    color: #06b6d4;
    border-color: #06b6d4;
}

QTabBar::tab:hover:!selected {
    color: #e5e5e5;
    background-color: #1a1a1a;
}

QListWidget,
QTreeWidget,
QTableWidget,
QTableView {
    background-color: #0a0a0a;
    alternate-background-color: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
    color: #e5e5e5;
    gridline-color: #222222;
}

QHeaderView::section {
    background-color: #111111;
    color: #a3a3a3;
    border: none;
    border-right: 1px solid #222222;
    padding: 8px;
    font-weight: 700;
}

QListWidget::item,
QTreeWidget::item {
    padding: 8px;
    border-bottom: 1px solid #1a1a1a;
}

QListWidget::item:hover,
QTreeWidget::item:hover,
QTableView::item:hover {
    background-color: #1a1a1a;
}

QListWidget::item:selected,
QTreeWidget::item:selected,
QTableView::item:selected {
    background-color: #06b6d4;
    color: #ffffff;
}

QProgressBar {
    background-color: #1a1a1a;
    border: 1px solid #222222;
    border-radius: 7px;
    color: #e5e5e5;
    min-height: 14px;
    text-align: center;
}

QProgressBar::chunk {
    background-color: #06b6d4;
    border-radius: 6px;
}

QSlider::groove:horizontal {
    background-color: #222222;
    height: 5px;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    background-color: #06b6d4;
    border: 2px solid #0a0a0a;
    width: 16px;
    height: 16px;
    margin: -6px 0;
    border-radius: 8px;
}

QScrollBar:vertical,
QScrollBar:horizontal {
    background-color: #0a0a0a;
    border: none;
    width: 12px;
    height: 12px;
    margin: 0;
}

QScrollBar::handle:vertical,
QScrollBar::handle:horizontal {
    background-color: #222222;
    border-radius: 6px;
    min-height: 32px;
    min-width: 32px;
}

QScrollBar::handle:vertical:hover,
QScrollBar::handle:horizontal:hover {
    background-color: #404040;
}

QScrollBar::add-line,
QScrollBar::sub-line,
QScrollBar::add-page,
QScrollBar::sub-page {
    background: none;
    border: none;
}

QMenuBar,
QMenu {
    background-color: #111111;
    color: #e5e5e5;
    border: 1px solid #222222;
}

QMenuBar::item,
QMenu::item {
    padding: 8px 12px;
}

QMenuBar::item:selected,
QMenu::item:selected {
    background-color: #06b6d4;
    color: #ffffff;
}

QStatusBar {
    background-color: #111111;
    color: #a3a3a3;
    border-top: 1px solid #222222;
}

QToolTip {
    background-color: #111111;
    border: 1px solid #222222;
    border-radius: 6px;
    color: #ffffff;
    padding: 6px 8px;
}
