/* ============================================================
   First-Person Narration Studio - Light Resource Theme
   Purpose: clean review/edit workspace with strong content contrast
   ============================================================ */

QWidget {
    background-color: #ffffff;
    color: #182235;
    font-family: system-ui, -apple-system, "Segoe UI", "Microsoft YaHei", "PingFang SC", "Hiragino Sans GB", Arial, sans-serif;
    font-size: 14px;
    selection-background-color: #0e7490;
    selection-color: #ffffff;
}

QMainWindow,
QDialog {
    background-color: #f6f8fb;
}

QWidget[objectName="left_panel"] {
    background-color: #ffffff;
    border-right: 1px solid #dbe3ee;
    min-width: 220px;
    max-width: 280px;
}

QLabel {
    background-color: transparent;
    color: #243247;
}

QLabel[objectName="app_title"] {
    color: #0e7490;
    font-size: 20px;
    font-weight: 700;
    padding: 20px 20px 16px;
    letter-spacing: 0px;
}

QLabel[objectName="page_title"],
QLabel[objectName="section_title"] {
    color: #0f172a;
    font-size: 18px;
    font-weight: 700;
}

QLabel[objectName="muted_label"],
QLabel[objectName="hint_label"] {
    color: #64748b;
}

QPushButton {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 7px;
    color: #182235;
    padding: 9px 16px;
    min-height: 34px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #f1f5f9;
    border-color: #0891b2;
    color: #0f172a;
}

QPushButton:pressed {
    background-color: #e2e8f0;
    border-color: #0e7490;
}

QPushButton:disabled {
    background-color: #f1f5f9;
    border-color: #dbe3ee;
    color: #94a3b8;
}

QPushButton[objectName="primary_button"] {
    background-color: #0891b2;
    border-color: #0891b2;
    color: #ffffff;
}

QPushButton[objectName="primary_button"]:hover {
    background-color: #0e7490;
    border-color: #0e7490;
}

QPushButton[objectName="primary_button"]:pressed {
    background-color: #155e75;
    border-color: #155e75;
}

QPushButton[objectName="secondary_button"] {
    background-color: #ffffff;
    border-color: #cbd5e1;
    color: #334155;
}

QPushButton[objectName="ghost_button"] {
    background-color: transparent;
    border-color: transparent;
    color: #64748b;
}

QPushButton[objectName="ghost_button"]:hover {
    background-color: #eef6f8;
    color: #0e7490;
}

QPushButton[objectName="danger_button"] {
    background-color: #e11d48;
    border-color: #e11d48;
    color: #ffffff;
}

QPushButton[objectName="danger_button"]:hover {
    background-color: #be123c;
    border-color: #be123c;
}

QPushButton[objectName="nav_button"] {
    background-color: transparent;
    border: none;
    border-radius: 7px;
    color: #475569;
    padding: 13px 18px;
    text-align: left;
    min-height: 42px;
    margin: 3px 10px;
}

QPushButton[objectName="nav_button"]:hover {
    background-color: #eef6f8;
    color: #0e7490;
}

QPushButton[objectName="nav_button"]:checked {
    background-color: #e0f7fb;
    border-left: 4px solid #0891b2;
    color: #0f172a;
    font-weight: 700;
}

QPushButton[objectName="nav_icon_btn"] {
    background-color: transparent;
    border: none;
    border-radius: 8px;
    min-width: 36px;
    min-height: 36px;
    padding: 4px;
}

QPushButton[objectName="nav_icon_btn"]:hover,
QPushButton[objectName="nav_icon_btn"]:checked {
    background-color: #eef6f8;
}

QLineEdit,
QTextEdit,
QPlainTextEdit,
QSpinBox,
QDoubleSpinBox {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 7px;
    color: #182235;
    padding: 9px 12px;
    min-height: 34px;
}

QLineEdit:hover,
QTextEdit:hover,
QPlainTextEdit:hover,
QSpinBox:hover,
QDoubleSpinBox:hover {
    border-color: #94a3b8;
}

QLineEdit:focus,
QTextEdit:focus,
QPlainTextEdit:focus,
QSpinBox:focus,
QDoubleSpinBox:focus {
    border-color: #0891b2;
}

QLineEdit:disabled,
QTextEdit:disabled,
QPlainTextEdit:disabled {
    background-color: #f1f5f9;
    color: #94a3b8;
}

QComboBox {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 7px;
    color: #182235;
    padding: 8px 12px;
    min-height: 34px;
}

QComboBox:hover,
QComboBox:focus {
    border-color: #0891b2;
}

QComboBox::drop-down {
    border: none;
    width: 26px;
}

QComboBox QAbstractItemView {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 7px;
    color: #182235;
    selection-background-color: #e0f7fb;
    selection-color: #0f172a;
    padding: 4px;
}

QCheckBox,
QRadioButton {
    color: #243247;
    spacing: 8px;
    background-color: transparent;
}

QCheckBox::indicator,
QRadioButton::indicator {
    width: 16px;
    height: 16px;
}

QCheckBox::indicator:unchecked,
QRadioButton::indicator:unchecked {
    background-color: #ffffff;
    border: 1px solid #94a3b8;
}

QCheckBox::indicator:checked,
QRadioButton::indicator:checked {
    background-color: #0891b2;
    border: 1px solid #0891b2;
}

QFrame,
QGroupBox {
    background-color: #ffffff;
    border: 1px solid #dbe3ee;
    border-radius: 8px;
}

QGroupBox {
    margin-top: 12px;
    padding: 14px 12px 12px 12px;
    font-weight: 700;
    color: #0f172a;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px;
    color: #0e7490;
}

QTabWidget::pane {
    background-color: #ffffff;
    border: 1px solid #dbe3ee;
    border-radius: 8px;
}

QTabBar::tab {
    background-color: #f6f8fb;
    border: 1px solid #dbe3ee;
    border-bottom: none;
    border-top-left-radius: 7px;
    border-top-right-radius: 7px;
    color: #64748b;
    padding: 9px 16px;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background-color: #ffffff;
    color: #0e7490;
    border-color: #0891b2;
}

QTabBar::tab:hover:!selected {
    color: #0f172a;
    background-color: #eef6f8;
}

QListWidget,
QTreeWidget,
QTableWidget,
QTableView {
    background-color: #ffffff;
    alternate-background-color: #f8fafc;
    border: 1px solid #dbe3ee;
    border-radius: 8px;
    color: #243247;
    gridline-color: #dbe3ee;
}

QHeaderView::section {
    background-color: #f1f5f9;
    color: #475569;
    border: none;
    border-right: 1px solid #dbe3ee;
    padding: 8px;
    font-weight: 700;
}

QListWidget::item,
QTreeWidget::item {
    padding: 8px;
    border-bottom: 1px solid #eef2f7;
}

QListWidget::item:hover,
QTreeWidget::item:hover,
QTableView::item:hover {
    background-color: #eef6f8;
}

QListWidget::item:selected,
QTreeWidget::item:selected,
QTableView::item:selected {
    background-color: #0e7490;
    color: #ffffff;
}

QProgressBar {
    background-color: #e2e8f0;
    border: 1px solid #dbe3ee;
    border-radius: 7px;
    color: #182235;
    min-height: 14px;
    text-align: center;
}

QProgressBar::chunk {
    background-color: #0891b2;
    border-radius: 6px;
}

QSlider::groove:horizontal {
    background-color: #dbe3ee;
    height: 5px;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    background-color: #0891b2;
    border: 2px solid #ffffff;
    width: 16px;
    height: 16px;
    margin: -6px 0;
    border-radius: 8px;
}

QScrollBar:vertical,
QScrollBar:horizontal {
    background-color: #f6f8fb;
    border: none;
    width: 12px;
    height: 12px;
    margin: 0;
}

QScrollBar::handle:vertical,
QScrollBar::handle:horizontal {
    background-color: #cbd5e1;
    border-radius: 6px;
    min-height: 32px;
    min-width: 32px;
}

QScrollBar::handle:vertical:hover,
QScrollBar::handle:horizontal:hover {
    background-color: #94a3b8;
}

QScrollBar::add-line,
QScrollBar::sub-line,
QScrollBar::add-page,
QScrollBar::sub-page {
    background: none;
    border: none;
}

QMenuBar,
QMenu {
    background-color: #ffffff;
    color: #182235;
    border: 1px solid #dbe3ee;
}

QMenuBar::item,
QMenu::item {
    padding: 8px 12px;
}

QMenuBar::item:selected,
QMenu::item:selected {
    background-color: #e0f7fb;
    color: #0f172a;
}

QStatusBar {
    background-color: #ffffff;
    color: #64748b;
    border-top: 1px solid #dbe3ee;
}

QToolTip {
    background-color: #0f172a;
    border: 1px solid #334155;
    border-radius: 6px;
    color: #ffffff;
    padding: 6px 8px;
}
