# AI服务API密钥配置
OPENAI_API_KEY=your_openai_api_key_here
QIANWEN_API_KEY=your_qianwen_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 视觉理解模型（升级为 Qwen3.7）
# 可选值：qwen3.7-plus, qwen3.7-max, gemini-3.5-flash, keye-vl-2.0
VISION_MODEL=qwen3.7-plus

# Qwen3.7 API Key（阿里云百炼 DashScope）
# 百炼兼容 OpenAI 格式，直接复用 QWEN_API_KEY 即可
QWEN_API_KEY=your_qwen_api_key_here
# VISION_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Gemini 3.5 Flash API Key（新增）
GEMINI_API_KEY=your_gemini_api_key_here

# PilotTTS API Key（新增，本地部署可为空）
PILOT_TTS_API_KEY=your_pilot_tts_api_key_here
PILOT_TTS_API_BASE=http://localhost:8080

# OmniVoice API Key（新增，本地部署可为空）
OMNIVOICE_API_KEY=your_omnivoice_api_key_here
OMNIVOICE_API_BASE=http://localhost:8081

# IndexTTS2 API Key（新增，本地部署可为空）
INDEXTTS2_API_KEY=your_indextts2_api_key_here
INDEXTTS2_API_BASE=http://localhost:8082

# 应用基本设置
APP_NAME=SceneFab
DEBUG=false
LOG_LEVEL=INFO

# 性能设置
MAX_MEMORY_USAGE=2048  # MB
CACHE_SIZE=100  # 预览帧数
MAX_CONCURRENT_TASKS=5

# 视频处理设置
FFMPEG_PATH=ffmpeg
DEFAULT_VIDEO_QUALITY=high
DEFAULT_RESOLUTION=1920x1080
DEFAULT_FPS=30

# AI模型设置
DEFAULT_AI_MODEL=openai
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7
AI_TIMEOUT=60

# 语音合成设置
TTS_ENGINE=edge-tts
DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
TTS_SPEED=1.0
TTS_PITCH=1.0

# 文件路径设置
DATA_DIR=./data
CACHE_DIR=./cache
LOG_DIR=./logs
EXPORT_DIR=./exports

# 网络设置
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=1

# 开发设置
DEV_MODE=false
TEST_MODE=false
PROFILE_PERFORMANCE=false