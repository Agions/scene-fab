{
  "name": "scenefab-docs",
  "version": "1.0.0",
  "description": "SceneFab documentation",
  "type": "module",
  "scripts": {
    "docs:build": "vitepress build",
    "docs:dev": "vitepress dev",
    "docs:spellcheck": "cspell \"**/*.md\" --config cspell.json",
    "docs:lint": "markdownlint-cli2 \"**/*.md\"",
    "docs:check": "npm run docs:lint && npm run docs:spellcheck",
    "docs:check-links": "node ../scripts/docs-check-links.mjs",
    "docs:check-external-links": "lychee --config ../.lychee.toml --offline 'docs/**/*.md' || lychee --config ../.lychee.toml 'docs/**/*.md'"
  },
  "devDependencies": {
    "cspell": "^8.17.2",
    "markdownlint-cli2": "^0.23.0",
    "vitepress": "^1.5.0"
  }
}
